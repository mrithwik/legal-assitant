# Litigation Prep Assistant - Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================
# PART 1: AI / LLM
# ============================================================
# Provider resolution order: OPENAI_API_KEY is used if set; otherwise
# OPENROUTER_API_KEY is tried; if neither is set the server will not start.
# Set exactly one of the two keys below.

# Option A: OpenAI directly (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Option B: OpenRouter (https://openrouter.ai/keys)
# Comment out OPENAI_API_KEY above and set this instead.
# OPENROUTER_API_KEY=sk-or-...

# Model name passed to whichever provider is active.
# OpenAI: gpt-4o, gpt-4o-mini, etc.
# OpenRouter: use provider-prefixed names, e.g. openai/gpt-4o, anthropic/claude-3-5-sonnet
MODEL=gpt-4o

# ============================================================
# PART 2: Pinecone (RAG vector store)
# ============================================================
# Create a serverless index in the Pinecone console:
#   - Dimensions: 1536 (required for text-embedding-3-small)
#   - Metric: cosine
# Copy the API key and index host URL from the console.
PINECONE_API_KEY=
# Preferred for serverless: full host URL, e.g. https://your-index-xxxx.svc.region.pinecone.io
PINECONE_INDEX_HOST=
# Alternative if your SDK resolves the endpoint from name only:
PINECONE_INDEX_NAME=
# Optional namespace (isolates vectors in the same index), e.g. prod or dev
PINECONE_NAMESPACE=

# ============================================================
# PART 3: Database
# ============================================================
# Dev default — SQLite, no setup needed:
DATABASE_URL=sqlite+aiosqlite:///./litigation.db
# Prod Postgres (Sodiq wires this after DB is provisioned):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/litigation

# ============================================================
# PART 4: Auth (Clerk)
# ============================================================
# John / Sodiq wire these when Clerk is set up
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev

# ============================================================
# PART 5: Observability (Langfuse)
# ============================================================
# Get keys from https://cloud.langfuse.com → Project Settings → API Keys
# Leave blank to disable tracing.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================
# PART 6: CORS
# ============================================================
# JSON array of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000"]
